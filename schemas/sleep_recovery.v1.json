{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iamjameskeane.github.io/garmin-claws/schemas/sleep_recovery.v1.json",
  "type": "object",
  "required": [
    "ok",
    "schema_version",
    "data",
    "warnings",
    "meta"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "schema_version": {
      "const": "garmin-claws.v1.sleep_recovery"
    },
    "data": {
      "type": "object",
      "required": [
        "date",
        "sleep_recovery",
        "training_impact",
        "main_limiter",
        "sleep",
        "health_status"
      ]
    },
    "warnings": {
      "type": "array"
    },
    "meta": {
      "type": "object"
    }
  }
}
